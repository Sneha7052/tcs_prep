#include <iostream>
#include<vector>
#include <unordered_map>
using namespace std;
int main()
{
	int n;
	cin>>n;
	int nums[n];
	for(int i=0;i<n;i++)
	{
	    cin>>nums[i];
	}
  unordered_map<int,int>mapp;
  for(int i = 0; i < n; i++) 
  {
      if(mapp[nums[i]]==0)
      {
          cout<<nums[i]<<" ";
      }
    mapp[nums[i]]++;
  }
  
  return 0;
}
