#include <unordered_map>
#include <iostream>
using namespace std;
int main()
{
    int ans;
    int n;
    cin >> n;
    int nums[n];
    for (int i = 0; i < n; i++)
    {
        cin >> nums[i];
    }
   unordered_map<int,int>mapp;
   for(int i=0;i<n;i++){
       mapp[nums[i]]++;
   }
   int maxi=0;
   for(auto it:mapp){
       if(it.second>maxi){
           maxi=it.second;
           ans=it.first;
       }
   }
   cout<<ans;
    return 0;
}
